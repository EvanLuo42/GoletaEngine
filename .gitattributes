# Auto-detect text files and normalize line endings to LF in the repo.
# Checkout uses native line endings (CRLF on Windows, LF elsewhere).
* text=auto eol=lf

# ---------- Source code (force LF) ----------
*.c     text eol=lf diff=cpp
*.cc    text eol=lf diff=cpp
*.cpp   text eol=lf diff=cpp
*.cxx   text eol=lf diff=cpp
*.h     text eol=lf diff=cpp
*.hh    text eol=lf diff=cpp
*.hpp   text eol=lf diff=cpp
*.hxx   text eol=lf diff=cpp
*.inl   text eol=lf diff=cpp
*.ipp   text eol=lf diff=cpp

# ---------- Build / config ----------
CMakeLists.txt       text eol=lf
*.cmake              text eol=lf
CMakePresets.json    text eol=lf
*.json               text eol=lf
*.yml                text eol=lf
*.yaml               text eol=lf
*.toml               text eol=lf
*.ini                text eol=lf
*.md                 text eol=lf diff=markdown
*.txt                text eol=lf

# ---------- Shaders ----------
*.hlsl   text eol=lf
*.hlsli  text eol=lf
*.glsl   text eol=lf
*.vert   text eol=lf
*.frag   text eol=lf
*.geom   text eol=lf
*.tesc   text eol=lf
*.tese   text eol=lf
*.comp   text eol=lf
*.mesh   text eol=lf
*.task   text eol=lf
*.rgen   text eol=lf
*.rchit  text eol=lf
*.rmiss  text eol=lf
*.rahit  text eol=lf
*.rint   text eol=lf
*.rcall  text eol=lf

# ---------- Scripts ----------
*.sh     text eol=lf
*.py     text eol=lf
# Keep Windows line endings for .bat/.cmd or they misbehave on Windows.
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# ---------- Binary assets (no diff, no EOL conversion) ----------
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.bmp    binary
*.tga    binary
*.tif    binary
*.tiff   binary
*.exr    binary
*.hdr    binary
*.psd    binary
*.ktx    binary
*.ktx2   binary
*.dds    binary
*.ico    binary

*.fbx    binary
*.obj    binary
*.gltf   binary
*.glb    binary
*.dae    binary
*.3ds    binary
*.blend  binary
*.usd    binary
*.usda   binary
*.usdc   binary
*.usdz   binary

*.wav    binary
*.ogg    binary
*.mp3    binary
*.flac   binary

*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary

*.zip    binary
*.7z     binary
*.rar    binary
*.gz     binary
*.tar    binary

*.lib    binary
*.dll    binary
*.pdb    binary
*.exp    binary
*.a      binary
*.so     binary
*.dylib  binary
*.exe    binary

# ---------- Pre-compiled shaders ----------
*.spv    binary
*.dxil   binary
*.cso    binary
*.fxc    binary

